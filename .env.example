# ─────────────────────────────────────────────────────────────
# honda-motoverso — Variables de entorno
# Copiar como .env y completar — NUNCA subir .env al repo
# ─────────────────────────────────────────────────────────────

# ── Dominios ──────────────────────────────────────────────────
DRUPAL_DOMAIN=api.honda-motoverso.com
PMA_DOMAIN=pma.honda-motoverso.com

# ── Base de datos ─────────────────────────────────────────────
DB_NAME=drupal
DB_USER=drupal
DB_PASS=CAMBIAR_PASSWORD_SEGURO
DB_ROOT_PASS=CAMBIAR_ROOT_PASSWORD_SEGURO

# ── Drupal ────────────────────────────────────────────────────
# Generar: openssl rand -base64 48 | tr -dc 'a-zA-Z0-9' | head -c 64
DRUPAL_HASH_SALT=CAMBIAR_HASH_64_CARACTERES

# Entorno: local | dev | stage | production
APP_ENV=production

# ── SSH al contenedor — Múltiples desarrolladores ────────────
#
# OPCIÓN A (recomendada): una variable por desarrollador
# Fácil de agregar/quitar sin afectar a los demás
#
# SSH_KEY_JULIAN=ssh-ed25519 AAAA... julian@mac
# SSH_KEY_ANDRES=ssh-ed25519 BBBB... andres@mac
# SSH_KEY_CARLOS=ssh-ed25519 CCCC... carlos@mac
#
# OPCIÓN B: todas en una variable separadas por \n
# SSH_PUBLIC_KEYS=ssh-ed25519 AAAA... dev1\nssh-ed25519 BBBB... dev2
#
# Para obtener tu llave: cat ~/.ssh/id_ed25519.pub
# Si no tienes llave: ssh-keygen -t ed25519 -C "tu@email.com"
# ─────────────────────────────────────────────────────────────

SSH_KEY_DEV1=
SSH_KEY_DEV2=
SSH_KEY_DEV3=

# ── CORS — JSON:API ───────────────────────────────────────────
# Separar múltiples dominios con coma
CORS_ORIGINS=http://localhost:3000,https://honda-motoverso.com

# ── Scripts locales — SSH al servidor Dokploy ─────────────────
DOKPLOY_SSH_HOST=54.166.21.233
DOKPLOY_SSH_PORT=2222
DOKPLOY_SSH_USER=root

# Nombres exactos de contenedores en Dokploy
# (ver con: docker ps en el servidor)
CONTAINER_MAIN=honda-motoverso-web
CONTAINER_STAGE=honda-motoverso-stage-web
CONTAINER_DEV=honda-motoverso-dev-web

# Nombres exactos de volúmenes en Dokploy
# (ver con: docker volume ls en el servidor)
VOLUME_FILES_MAIN=honda_motoverso_files
VOLUME_DB_MAIN=honda_motoverso_db
