# ── Entorno ──────────────────────────────────────────────────
APP_ENV=local

# ── Dominios (Dokploy UI) ────────────────────────────────────
# En Dokploy se recomienda configurar los dominios desde la UI.
# Estos valores solo documentan el entorno.
DRUPAL_DOMAIN=api-stage.midominio.com
PMA_DOMAIN=pma-stage.midominio.com

# ── Base de datos ────────────────────────────────────────────
DB_NAME=drupal
DB_USER=drupal
DB_PASS=drupal
DB_ROOT_PASS=root
DB_WAIT_RETRIES=60
DB_WAIT_DELAY=2

# ── Drupal ───────────────────────────────────────────────────
DRUPAL_HASH_SALT=CHANGE_ME_HASH_SALT
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Instalación automática local ─────────────────────────────
# true  → instala Drupal si la base está vacía
# false → solo arranca el contenedor
INSTALL_SITE=true

# true  → drush si --existing-config
# false → drush si standard
INSTALL_FROM_CONFIG=false
INSTALL_PROFILE=standard
SITE_NAME=Honda Motoverso Local
SITE_MAIL=admin@example.com
ACCOUNT_NAME=admin
ACCOUNT_MAIL=admin@example.com
ACCOUNT_PASS=admin123456

# ── Puertos locales (solo docker-compose.local.yml) ──────────
LOCAL_WEB_PORT=8080
LOCAL_PMA_PORT=8081
LOCAL_DB_PORT=33066
LOCAL_SSH_PORT=2222

# ── SSH al contenedor (opcional) ─────────────────────────────
SSH_PUBLIC_KEYS=
SSH_PUBLIC_KEY=
SSH_KEY_DEV1=
SSH_KEY_DEV2=
SSH_KEY_DEV3=
SSH_KEY_DEV4=
SSH_KEY_DEV5=
